# Required — set this in Render dashboard / env group
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=change-me-to-a-long-random-string

# Your Render service URL + any custom domains (comma-separated, no spaces)
DJANGO_ALLOWED_HOSTS=your-service-name.onrender.com

# Render injects this automatically when you attach a PostgreSQL database
DATABASE_URL=postgres://user:password@host:5432/dbname

# CORS — set to your frontend URL(s)
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app
CSRF_TRUSTED_ORIGINS=https://your-service-name.onrender.com,https://your-frontend.vercel.app
